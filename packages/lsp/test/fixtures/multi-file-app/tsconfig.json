{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": ["**/*.tsx", "**/*.ts"]
}
